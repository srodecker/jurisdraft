# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Google Gemini API key (required for document extraction)
GOOGLE_API_KEY=your_google_api_key_here

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Srodecker login credentials (password hash - REQUIRED)
# This is used to initialize the srodecker profile on server startup.
# Format: "salt:hash" where salt and hash are hex strings from scrypt hashing.
# On Vercel: Set this environment variable in your Vercel project settings.
# The srodecker profile will be auto-created on deployment.
SRODECKER_PASSWORD_HASH=f4a11aedd044bc9131f3b8203e25ec12:166e6fc5d28bb935fc6257c4f7988bde249820f2023d112ad17fed48bb3ede0d838ac693d1c17f0b07234eeb8254ac0980f014c4365d2b5028067da5a7afc23f
