# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Google Gemini API key (required for document extraction)
GOOGLE_API_KEY=your_google_api_key_here

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Attorney login password.
# When set, a "Login" button appears in the workspace.
# Logging in unlocks: private DOCX templates + attorney signature auto-fill.
# Leave blank or omit to disable attorney mode entirely.
ATTORNEY_PASSWORD=choose_a_strong_password_here
